{
  "name": "student-rental-app",
  "version": "1.0.0",
  "private": true,
  "description": "Student-to-student rental platform demo web application",
  "scripts": {
    "dev": "concurrently -k -n api,web \"node --watch server/server.js\" \"vite --port 5173\"",
    "dev:api": "node --watch server/server.js",
    "dev:web": "vite --port 5173",
    "start": "node server/server.js",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "seed": "node server/scripts/seed.js",
    "reset-db": "node server/scripts/seed.js --force"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "vite": "^5.4.21"
  }
}